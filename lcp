#Longest Common Prefix
Problem -> Find the longest common prefix between the array of string
Approach -> intial case set rv_pref to first string then compare with rest until the characters are matching 
if not matched exit and truncate the prefix
comp -> o(n2)

method longest_common_prefix.
if it_words is initial. return. endif.
rv_pref = it_words[ 1 ].
data(lv_l) = strlen( rv_pref ).
loop at it_words into data(lw_words) from 2.
if lv_l > strlen( lw_words ). lv_l = strlen( lw_words ). endif.
do lv_l times.
lv_i = sy-index - 1.
if rv_pref+lv_i(1) ne lw_words+lv_i(1).
data(lv_r) = lv_l - lv_i.
rv_pref = rv_pref+0(lv_i). return.
endif.
enddo.
endloop.
endmethod.