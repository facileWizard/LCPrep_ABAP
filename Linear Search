#Implement Liner Search - o(n) comp

METHODS: linear_search
IMPORTING
it_array TYPE ty_int_table
iv_target TYPE i
RETURNING
VALUE(rv_index) TYPE i.

method linear_search.
rv_index = -1.
loop at it_array into data(lw_array).
if ( iv_target eq lw_array ).
rv_index = sy-index.
exit.
endif.
endloop.
endmethod.
