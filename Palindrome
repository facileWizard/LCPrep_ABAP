#Implement Palindrome 
Complexity - O(n)
Using two pointer method to track from back and front
ends in n/2 times iteration

method palindrome.
is_palindrome = abap_true.
data(lv_len) = strlen( iv_string ).
do lv_len div 2 times.
data(lv_i) = lv_len - sy-index.
data(lv_leftpointer) = sy-index - 1.
if iv_string+lv_leftpointer(1) eq iv_string+lv_i(1).
else.
is_palindrome = abap_false.
exit.
endif.
enddo.
endmethod.

# is valid palindrome using regex for pattern matching -> impt for ABAP

method is_valid_palindrome. "Alphanumeric Only)
rv_result = abap_false.
do strlen( iv_input ) times.
lv_i = sy-index - 1.
data: lv_valid type string.
FIND REGEX '^[A-Za-z0-9]$' IN iv_input+lv_i(1) MATCH COUNT DATA(lv_count).
if lv_count > 0.
lv_valid = lv_valid && iv_input+lv_i(1).
endif.
enddo.
lv_valid = to_lower( val = lv_valid ).
lv_len = strlen( lv_valid ). lv_j = lv_len - 1. lv_i = 0.
do lv_len / 2 times.
if lv_valid+lv_i(1) ne lv_valid+lv_j(1).
return.
endif.
lv_i = lv_i + 1.
lv_j = lv_j - 1.
enddo.
rv_result = abap_true.
endmethod.