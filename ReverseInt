#Reverse Integer 
Approach: Covert number to string and then traverse from back using length offset and concatenate
in a new string and return the string as a result.
comp: o(n)


method reverse_integer.
"using offset
data lv_result type string.
DATA(lv_input_str) = |{ iv_string }|.
data(lv_strlen) = strlen( lv_input_str ) .
do lv_strlen times.
data(lv_i) = lv_strlen - sy-index.
lv_result = lv_result && lv_input_str+lv_i(1).
enddo.
rv_string = lv_result.
endmethod.

#Same question but using absolute and div method 
No extra space and no string conversion

method reverse_integer_abs.
data(lv_number) = abs( iv_number ).
while lv_number ne 0.
data(digit) = lv_number mod 10.
lv_number = lv_number div 10.
rv_number = rv_number * 10 + digit.
endwhile.
if iv_number < 0. rv_number = rv_number * -1. endif.
endmethod.